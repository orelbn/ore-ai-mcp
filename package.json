{
	"name": "ore-ai-mcp",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "bun test",
		"build": "wrangler deploy --dry-run --env=\"\"",
		"deploy:prod": "wrangler deploy --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"context:validate": "bun run scripts/context-validate.ts",
		"context:sync": "bun run scripts/context-sync.ts",
		"tool:dev": "bun run tool:build && bun run internal/local-mcp-dev/server.ts",
		"tool:api": "bun run internal/local-mcp-dev/server.ts",
		"tool:build": "vite build --config internal/local-mcp-dev/ui/vite.config.ts",
		"tool:ui": "vite --config internal/local-mcp-dev/ui/vite.config.ts"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260324.1",
		"@vitejs/plugin-react": "^6.0.1",
		"vite": "^8.0.2",
		"wrangler": "^4.77.0"
	}
}
