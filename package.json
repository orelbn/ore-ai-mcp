    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2",
    "wrangler": "^4.77.0"
  },
