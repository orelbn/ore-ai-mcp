{
  "name": "ore-ai-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "build": "wrangler deploy --dry-run --env=\"\"",
    "deploy:prod": "wrangler deploy --env production",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "context:validate": "bun run scripts/context-validate.ts",
    "context:sync": "bun run scripts/context-sync.ts",
    "tool:dev": "bun run tool:build && bun run internal/local-mcp-dev/server.ts",
    "tool:api": "bun run internal/local-mcp-dev/server.ts",
    "tool:build": "vp build internal/local-mcp-dev/ui",
    "tool:ui": "vp dev internal/local-mcp-dev/ui --host 127.0.0.1 --port 4318"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2",
    "wrangler": "^4.77.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
