{
	"name": "ore-ai-mcp",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"hooks:install": "git config core.hooksPath .githooks",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "bun test",
		"build": "wrangler deploy --dry-run --env=\"\"",
		"deploy:prod": "wrangler deploy --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"context:validate": "bun run scripts/context-validate.ts",
		"context:sync": "bun run scripts/context-sync.ts",
		"github-insights:validate": "bun run scripts/github-insights-validate.ts",
		"github-insights:sync": "bun run scripts/github-insights-sync.ts"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.43",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"agents": "^0.7.6",
		"ai": "^6.0.116",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260311.1",
		"@biomejs/biome": "^2.4.6",
		"@cloudflare/workers-types": "^4.20260312.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"wrangler": "^4.72.0"
	}
}
