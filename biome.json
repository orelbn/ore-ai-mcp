{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error"
			},
			"style": {
				"useImportType": "error"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!cloudflare-env.d.ts",
			"!.wrangler",
			"!internal/local-mcp-dev/ui/dist"
		]
	}
}
