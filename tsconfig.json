{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@mocks/*": ["./mocks/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node", "bun-types"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "internal/**/*.d.ts",
    "internal/**/*.ts",
    "internal/**/*.tsx",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "mocks/**/*.ts"
  ]
}
