/**
 * Template Wrangler config tracked in git.
 * Copy to wrangler.jsonc and replace placeholder bucket names for your account.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ore-ai-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"workers_dev": false,
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"r2_buckets": [
		{
			"binding": "CONTEXT_BUCKET",
			"bucket_name": "your-context-bucket",
			"preview_bucket_name": "your-context-bucket"
		}
	]
}
